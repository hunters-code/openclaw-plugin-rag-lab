{
  "name": "openclaw-plugin-rag-lab",
  "version": "0.0.1",
  "description": "Plugin OpenClaw: daftar tugas sederhana in-memory (contoh multi-tool)",
  "type": "module",
  "main": "dist/index.js",
  "keywords": [
    "openclaw",
    "plugin",
    "tasks",
    "todo"
  ],
  "license": "MIT",
  "dependencies": {
    "@orbit-0g/sdk": "^0.1.7",
    "@sinclair/typebox": "0.34.48"
  },
  "devDependencies": {
    "openclaw": "latest",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  }
}
